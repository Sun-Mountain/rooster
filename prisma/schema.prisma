generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPER
}

model Class {
  id            String   @id @default(cuid())
  name          String
  description   String?
  classDetails  ClassTermDetails[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("class")
}

model ClassTermDetails {
  id          String   @id @default(cuid())
  classId     String
  termId      String
  details     String?
  daysTimes   DayTimes[] @relation("ClassDaysTimes")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([classId, termId])
  @@map("class_term_details")
}

model DayTimes {
  id                  String   @id @default(cuid())
  dayOfWeek           String
  startTime           String
  endTime             String
  classTermDetailsId  String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  classDetails        ClassTermDetails @relation("ClassDaysTimes", fields: [classTermDetailsId], references: [id], onDelete: Cascade)

  @@map("day_time")
}

model Term {
  id          String   @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  classes     ClassTermDetails[]
  live        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("term")
}

model ContactAddress {
  id               String   @id @default(cuid())
  street1          String?
  street2          String?
  city             String?
  state            String?
  zip              String?
  country          String?  @default("USA")
  secondaryEmail   String?
  phone            String?
  preferredContact String?  @default("phone")
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId])
  @@map("contact_address")
}

model EmergencyContact {
  id           String   @id @default(cuid())
  firstName    String?
  lastName     String?
  relationship String?
  phone        String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId])
  @@map("emergency_contact")
}

model User {
  id            String            @id @default(cuid())
  name          String
  firstName     String
  lastName      String
  email         String
  emailVerified Boolean
  role          Role              @default(USER)
  contact       ContactAddress?
  emergency     EmergencyContact?
  pronouns      String?
  otherPronouns String?
  image         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}
